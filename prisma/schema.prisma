generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  MENTOR
  PARENT
  COUNSELOR
  ADMIN

  @@map("user_role")
}

enum SubscriptionPlan {
  BASIC
  PLUS
  PRO

  @@map("subscription_plan")
}

enum AccountStatus {
  ACTIVE
  LOCKED
  SUSPENDED
  DELETED

  @@map("account_status")
}

enum TokenStatus {
  ACTIVE
  USED
  REVOKED
  EXPIRED

  @@map("token_status")
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED

  @@map("session_status")
}

enum ApplicationStatus {
  RESEARCHING
  APPLYING
  SUBMITTED
  ACCEPTED
  WAITLISTED
  REJECTED

  @@map("application_status")
}

enum EssayStatus {
  DRAFT
  IN_REVIEW
  REVISED
  FINAL

  @@map("essay_status")
}

enum MessageStatus {
  SENT
  READ
  ARCHIVED

  @@map("message_status")
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED

  @@map("notification_status")
}

enum SecurityEventSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@map("security_event_severity")
}

model User {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName               String                   @map("first_name") @db.VarChar(80)
  lastName                String                   @map("last_name") @db.VarChar(80)
  email                   String                   @unique @db.Citext
  passwordHash            String                   @map("password_hash") @db.VarChar(255)
  role                    UserRole
  status                  AccountStatus            @default(ACTIVE)
  plan                    SubscriptionPlan         @default(BASIC)
  stripeCustomerId        String?                  @unique @map("stripe_customer_id") @db.VarChar(255)
  stripeSubscriptionId    String?                  @unique @map("stripe_subscription_id") @db.VarChar(255)
  subscriptionStatus      String?                  @map("subscription_status") @db.VarChar(40)
  subscriptionCurrentPeriodEnd DateTime?           @map("subscription_current_period_end") @db.Timestamptz(6)
  emailVerified           Boolean                  @default(false) @map("email_verified")
  emailVerifiedAt         DateTime?                @map("email_verified_at") @db.Timestamptz(6)
  termsAcceptedAt         DateTime                 @map("terms_accepted_at") @db.Timestamptz(6)
  failedLoginCount        Int                      @default(0) @map("failed_login_count")
  lockedUntil             DateTime?                @map("locked_until") @db.Timestamptz(6)
  lastLoginAt             DateTime?                @map("last_login_at") @db.Timestamptz(6)
  createdAt               DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt               DateTime?                @map("deleted_at") @db.Timestamptz(6)

  sessions                Session[]
  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  loginHistory            LoginHistory[]
  securityEvents          SecurityEvent[]
  auditLogs               ActivityLog[]            @relation("ActivityActor")
  notifications           Notification[]
  studentProfile          StudentProfile?
  mentorProfile           MentorProfile?
  counselorProfile        CounselorProfile?
  messagesSent            Message[]                @relation("MessagesSent")
  messagesReceived        Message[]                @relation("MessagesReceived")
  preludeMatchQuestionnaire PreludeMatchQuestionnaire?

  @@index([role, status], map: "idx_users_role_status")
  @@index([emailVerified, status], map: "idx_users_verified_status")
  @@index([lockedUntil], map: "idx_users_locked_until")
  @@index([plan, status], map: "idx_users_plan_status")
  @@index([subscriptionStatus], map: "idx_users_subscription_status")
  @@index([subscriptionCurrentPeriodEnd], map: "idx_users_subscription_period_end")
  @@map("users")
}

model Organization {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String             @db.VarChar(180)
  slug              String             @unique @db.VarChar(180)
  domain            String?            @db.VarChar(180)
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  studentProfiles   StudentProfile[]
  counselorProfiles CounselorProfile[]

  @@index([name], map: "idx_organizations_name")
  @@map("organizations")
}

model StudentProfile {
  id                     String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                 String               @unique @map("user_id") @db.Uuid
  organizationId         String?              @map("organization_id") @db.Uuid
  graduationYear         Int?                 @map("graduation_year")
  highSchool             String?              @map("high_school") @db.VarChar(180)
  location               String?              @db.VarChar(160)
  targetMajors           String[]             @default([]) @map("target_majors")
  gpa                    Decimal?             @db.Decimal(4, 2)
  testScores             Json                 @default("{}") @map("test_scores") @db.JsonB
  progress               Json                 @default("{}") @db.JsonB
  preferences            Json                 @default("{}") @db.JsonB
  createdAt              DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization           Organization?        @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  mentorAssignments      MentorAssignment[]
  collegeApplications    CollegeApplication[]
  essays                 Essay[]
  preludeMatchQuestionnaires PreludeMatchQuestionnaire[]

  @@index([organizationId], map: "idx_student_profiles_org")
  @@index([graduationYear], map: "idx_student_profiles_grad_year")
  @@map("student_profiles")
}


model PreludeMatchQuestionnaire {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String         @unique @map("user_id") @db.Uuid
  studentProfileId   String?        @map("student_profile_id") @db.Uuid
  answers            Json           @db.JsonB
  completionPercent  Int            @default(0) @map("completion_percent")
  submittedAt        DateTime       @default(now()) @map("submitted_at") @db.Timestamptz(6)
  createdAt          DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentProfile     StudentProfile? @relation(fields: [studentProfileId], references: [id], onDelete: SetNull)

  @@index([studentProfileId, submittedAt], map: "idx_prelude_match_student_submitted")
  @@index([submittedAt], map: "idx_prelude_match_submitted_at")
  @@map("prelude_match_questionnaires")
}

model MentorProfile {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String              @unique @map("user_id") @db.Uuid
  college           String?             @db.VarChar(180)
  major             String?             @db.VarChar(180)
  bio               String?             @db.Text
  specialties       String[]            @default([])
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  mentorAssignments MentorAssignment[]

  @@index([college], map: "idx_mentor_profiles_college")
  @@map("mentor_profiles")
}

model CounselorProfile {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String        @unique @map("user_id") @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  title          String?       @db.VarChar(120)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId], map: "idx_counselor_profiles_org")
  @@map("counselor_profiles")
}

model MentorAssignment {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mentorProfileId String         @map("mentor_profile_id") @db.Uuid
  studentProfileId String        @map("student_profile_id") @db.Uuid
  active          Boolean        @default(true)
  assignedAt      DateTime       @default(now()) @map("assigned_at") @db.Timestamptz(6)
  endedAt         DateTime?      @map("ended_at") @db.Timestamptz(6)
  notes           String?        @db.Text

  mentorProfile   MentorProfile  @relation(fields: [mentorProfileId], references: [id], onDelete: Cascade)
  studentProfile  StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@unique([mentorProfileId, studentProfileId], map: "uq_mentor_assignments_mentor_student")
  @@index([studentProfileId, active], map: "idx_mentor_assignments_student_active")
  @@index([mentorProfileId, active], map: "idx_mentor_assignments_mentor_active")
  @@map("mentor_assignments")
}

model Session {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String        @map("user_id") @db.Uuid
  sessionTokenHash String        @unique @map("session_token_hash") @db.VarChar(255)
  status           SessionStatus @default(ACTIVE)
  device           String?       @db.VarChar(160)
  browser          String?       @db.VarChar(160)
  ipAddress        String?       @map("ip_address") @db.Inet
  userAgent        String?       @map("user_agent") @db.Text
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  lastSeenAt       DateTime?     @map("last_seen_at") @db.Timestamptz(6)
  expiresAt        DateTime      @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime?     @map("revoked_at") @db.Timestamptz(6)

  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens    RefreshToken[]

  @@index([userId, status, expiresAt], map: "idx_sessions_user_status_expires")
  @@index([expiresAt], map: "idx_sessions_expires_at")
  @@map("sessions")
}

model RefreshToken {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String      @map("user_id") @db.Uuid
  sessionId         String      @map("session_id") @db.Uuid
  tokenHash         String      @unique @map("token_hash") @db.VarChar(255)
  status            TokenStatus @default(ACTIVE)
  issuedAt          DateTime    @default(now()) @map("issued_at") @db.Timestamptz(6)
  expiresAt         DateTime    @map("expires_at") @db.Timestamptz(6)
  revokedAt         DateTime?   @map("revoked_at") @db.Timestamptz(6)
  replacedByTokenId String?     @map("replaced_by_token_id") @db.Uuid
  ipAddress         String?     @map("ip_address") @db.Inet
  userAgent         String?     @map("user_agent") @db.Text

  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  session           Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  replacedBy        RefreshToken? @relation("RefreshTokenRotation", fields: [replacedByTokenId], references: [id], onDelete: SetNull)
  replaces          RefreshToken[] @relation("RefreshTokenRotation")

  @@index([userId, status, expiresAt], map: "idx_refresh_tokens_user_status_expires")
  @@index([sessionId, status], map: "idx_refresh_tokens_session_status")
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String      @map("user_id") @db.Uuid
  tokenHash  String      @unique @map("token_hash") @db.VarChar(255)
  status     TokenStatus @default(ACTIVE)
  expiresAt  DateTime    @map("expires_at") @db.Timestamptz(6)
  usedAt     DateTime?   @map("used_at") @db.Timestamptz(6)
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  requestIp  String?     @map("request_ip") @db.Inet
  userAgent  String?     @map("user_agent") @db.Text

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, expiresAt], map: "idx_password_reset_tokens_user_status_expires")
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String      @map("user_id") @db.Uuid
  tokenHash  String      @unique @map("token_hash") @db.VarChar(255)
  status     TokenStatus @default(ACTIVE)
  expiresAt  DateTime    @map("expires_at") @db.Timestamptz(6)
  usedAt     DateTime?   @map("used_at") @db.Timestamptz(6)
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, expiresAt], map: "idx_email_verification_tokens_user_status_expires")
  @@map("email_verification_tokens")
}

model LoginHistory {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  emailAttempted String?  @map("email_attempted") @db.Citext
  success        Boolean
  failureReason  String?  @map("failure_reason") @db.VarChar(160)
  device         String?  @db.VarChar(160)
  browser        String?  @db.VarChar(160)
  ipAddress      String?  @map("ip_address") @db.Inet
  userAgent      String?  @map("user_agent") @db.Text
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt], map: "idx_login_history_user_created")
  @@index([emailAttempted, createdAt], map: "idx_login_history_email_created")
  @@index([ipAddress, createdAt], map: "idx_login_history_ip_created")
  @@map("login_history")
}

model SecurityEvent {
  id          String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String?               @map("user_id") @db.Uuid
  eventType   String                @map("event_type") @db.VarChar(100)
  severity    SecurityEventSeverity @default(INFO)
  ipAddress   String?               @map("ip_address") @db.Inet
  userAgent   String?               @map("user_agent") @db.Text
  metadata    Json                  @default("{}") @db.JsonB
  createdAt   DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  user        User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt], map: "idx_security_events_user_created")
  @@index([eventType, createdAt], map: "idx_security_events_type_created")
  @@index([severity, createdAt], map: "idx_security_events_severity_created")
  @@map("security_events")
}

model RateLimitBucket {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key           String   @db.VarChar(255)
  route         String   @db.VarChar(255)
  windowStart   DateTime @map("window_start") @db.Timestamptz(6)
  windowSeconds Int      @map("window_seconds")
  requestCount  Int      @default(0) @map("request_count")
  blockedUntil  DateTime? @map("blocked_until") @db.Timestamptz(6)
  metadata      Json     @default("{}") @db.JsonB
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([key, route, windowStart], map: "uq_rate_limit_buckets_key_route_window")
  @@index([blockedUntil], map: "idx_rate_limit_buckets_blocked_until")
  @@map("rate_limit_buckets")
}

model StripeWebhookEvent {
  id          String   @id @db.VarChar(255)
  eventType   String   @map("event_type") @db.VarChar(120)
  processedAt DateTime @default(now()) @map("processed_at") @db.Timestamptz(6)
  payload     Json     @default("{}") @db.JsonB

  @@index([eventType, processedAt], map: "idx_stripe_webhook_events_type_processed")
  @@map("stripe_webhook_events")
}

model Notification {
  id        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String             @map("user_id") @db.Uuid
  title     String             @db.VarChar(160)
  body      String             @db.Text
  status    NotificationStatus @default(UNREAD)
  metadata  Json               @default("{}") @db.JsonB
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  readAt    DateTime?          @map("read_at") @db.Timestamptz(6)

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt], map: "idx_notifications_user_status_created")
  @@map("notifications")
}

model Message {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  senderId    String        @map("sender_id") @db.Uuid
  recipientId String        @map("recipient_id") @db.Uuid
  subject     String?       @db.VarChar(180)
  body        String        @db.Text
  status      MessageStatus @default(SENT)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  readAt      DateTime?     @map("read_at") @db.Timestamptz(6)

  sender      User          @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  recipient   User          @relation("MessagesReceived", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([senderId, createdAt], map: "idx_messages_sender_created")
  @@index([recipientId, status, createdAt], map: "idx_messages_recipient_status_created")
  @@map("messages")
}

model CollegeApplication {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentProfileId String            @map("student_profile_id") @db.Uuid
  collegeName      String            @map("college_name") @db.VarChar(180)
  deadline         DateTime?         @db.Date
  status           ApplicationStatus @default(RESEARCHING)
  applicationRound String?           @map("application_round") @db.VarChar(80)
  portalUrl        String?           @map("portal_url") @db.VarChar(2048)
  metadata         Json              @default("{}") @db.JsonB
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  studentProfile   StudentProfile    @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  essays           Essay[]

  @@index([studentProfileId, status], map: "idx_college_applications_student_status")
  @@index([deadline], map: "idx_college_applications_deadline")
  @@map("college_applications")
}

model Essay {
  id                   String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentProfileId     String              @map("student_profile_id") @db.Uuid
  collegeApplicationId String?             @map("college_application_id") @db.Uuid
  title                String              @db.VarChar(180)
  prompt               String?             @db.Text
  content              String              @default("") @db.Text
  status               EssayStatus         @default(DRAFT)
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  studentProfile       StudentProfile      @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  collegeApplication   CollegeApplication? @relation(fields: [collegeApplicationId], references: [id], onDelete: SetNull)

  @@index([studentProfileId, status], map: "idx_essays_student_status")
  @@index([collegeApplicationId], map: "idx_essays_application")
  @@map("essays")
}

model ActivityLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String   @db.VarChar(120)
  entityType  String   @map("entity_type") @db.VarChar(120)
  entityId    String?  @map("entity_id") @db.Uuid
  ipAddress   String?  @map("ip_address") @db.Inet
  userAgent   String?  @map("user_agent") @db.Text
  metadata    Json     @default("{}") @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  actor       User?    @relation("ActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt], map: "idx_activity_logs_actor_created")
  @@index([entityType, entityId, createdAt], map: "idx_activity_logs_entity_created")
  @@index([action, createdAt], map: "idx_activity_logs_action_created")
  @@map("activity_logs")
}

model Meeting {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title          String   @db.VarChar(180)
  studentUserId  String?  @map("student_user_id") @db.Uuid
  mentorUserId   String?  @map("mentor_user_id") @db.Uuid
  studentId      String?  @map("student_slug") @db.VarChar(80)
  mentorId       String?  @map("mentor_slug") @db.VarChar(80)
  meetingType    String   @default("zoom") @map("meeting_type") @db.VarChar(20)
  startTime      DateTime @map("start_time") @db.Timestamptz(6)
  endTime        DateTime @map("end_time") @db.Timestamptz(6)
  timeZone       String   @default("America/New_York") @map("time_zone") @db.VarChar(64)
  zoomMeetingId  String?  @map("zoom_meeting_id") @db.VarChar(64)
  zoomJoinUrl    String?  @map("zoom_join_url") @db.VarChar(2048)
  zoomHostUrl    String?  @map("zoom_host_url") @db.VarChar(2048)
  zoomPassword   String?  @map("zoom_password") @db.VarChar(64)
  status         String   @default("pending") @db.VarChar(20)
  notes          String   @default("") @db.Text
  isPrivate      Boolean  @default(false) @map("is_private")
  idempotencyKey String?  @unique @map("idempotency_key") @db.VarChar(128)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([studentUserId, status], map: "idx_meetings_student_user_status")
  @@index([mentorUserId, status], map: "idx_meetings_mentor_user_status")
  @@map("meetings")
}

model PromoCode {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  publicCode             String    @map("public_code") @db.VarChar(64)
  codeHash               String    @unique @map("code_hash") @db.VarChar(64)
  description            String?   @db.Text
  campaignName           String?   @map("campaign_name") @db.VarChar(120)
  applicablePlan         String    @default("basic") @map("applicable_plan") @db.VarChar(20)
  discountType           String    @default("complimentary") @map("discount_type") @db.VarChar(20)
  discountValue          Decimal?  @map("discount_value") @db.Decimal(10, 2)
  startsAt               DateTime? @map("starts_at") @db.Timestamptz(6)
  expiresAt              DateTime? @map("expires_at") @db.Timestamptz(6)
  maxRedemptions         Int?      @map("max_redemptions")
  maxRedemptionsPerUser  Int       @default(1) @map("max_redemptions_per_user")
  currentRedemptionCount Int       @default(0) @map("current_redemption_count")
  singleUse              Boolean   @default(false) @map("single_use")
  active                 Boolean   @default(true)
  eligibleEmailDomains   String[]  @default([]) @map("eligible_email_domains")
  eligibleEmails         String[]  @default([]) @map("eligible_emails")
  newUsersOnly           Boolean   @default(true) @map("new_users_only")
  accessDurationDays     Int?      @map("access_duration_days")
  renewalBehavior        String    @default("requires_payment") @map("renewal_behavior") @db.VarChar(40)
  internalNotes          String?   @map("internal_notes") @db.Text
  revokedAt              DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdById            String?   @map("created_by") @db.Uuid
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  redemptions            PromoRedemption[]

  @@index([campaignName], map: "idx_promo_codes_campaign")
  @@index([active, expiresAt], map: "idx_promo_codes_active_expires")
  @@map("promo_codes")
}

model PromoRedemption {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  promoCodeId       String   @map("promo_code_id") @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  email             String   @db.Citext
  redeemedAt        DateTime @default(now()) @map("redeemed_at") @db.Timestamptz(6)
  planId            String   @map("plan_id") @db.VarChar(20)
  promotionStartsAt DateTime @default(now()) @map("promotion_starts_at") @db.Timestamptz(6)
  promotionEndsAt   DateTime? @map("promotion_ends_at") @db.Timestamptz(6)
  paymentWaived     Boolean  @default(true) @map("payment_waived")
  campaignName      String?  @map("campaign_name") @db.VarChar(120)

  promoCode         PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Restrict)

  @@unique([promoCodeId, userId], map: "uq_promo_redemptions_code_user")
  @@index([userId, redeemedAt], map: "idx_promo_redemptions_user_redeemed")
  @@index([promoCodeId, redeemedAt], map: "idx_promo_redemptions_code_redeemed")
  @@map("promo_redemptions")
}

model PromoValidationAttempt {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  codeHash  String?  @map("code_hash") @db.VarChar(64)
  email     String?  @db.Citext
  ipHash    String?  @map("ip_hash") @db.VarChar(64)
  success   Boolean
  errorCode String?  @map("error_code") @db.VarChar(40)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt], map: "idx_promo_validation_attempts_created")
  @@map("promo_validation_attempts")
}

model AiKnowledgeChunk {
  id             String    @id @default(cuid())
  sourceId       String
  sourceName     String
  sourceUrl      String
  category       String
  title          String
  content        String
  sourceFile     String?   @map("source_file")
  sourceType     String?   @map("source_type")
  metadata       Json      @default("{}")
  searchableText String?   @map("searchable_text")
  embedding      Unsupported("vector")?
  lastVerified   DateTime
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([sourceId], map: "idx_ai_knowledge_chunks_source_id")
  @@index([category], map: "idx_ai_knowledge_chunks_category")
  @@index([sourceType], map: "idx_ai_knowledge_chunks_source_type")
  @@index([lastVerified], map: "idx_ai_knowledge_chunks_last_verified")
  @@map("ai_knowledge_chunks")
}
