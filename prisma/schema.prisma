generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  MODERATOR
  ADMIN

  @@map("user_role")
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  BANNED

  @@map("account_status")
}

enum TokenStatus {
  ACTIVE
  USED
  REVOKED
  EXPIRED

  @@map("token_status")
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED

  @@map("session_status")
}

enum MatchStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
  EXPIRED

  @@map("match_status")
}

enum MatchParticipantOutcome {
  PENDING
  WIN
  LOSS
  DRAW
  NO_CONTEST

  @@map("match_participant_outcome")
}

enum ReportStatus {
  OPEN
  TRIAGED
  ACTIONED
  DISMISSED
  CLOSED

  @@map("report_status")
}

enum ModerationActionType {
  WARNING
  CONTENT_REMOVAL
  TEMPORARY_SUSPENSION
  PERMANENT_BAN
  ACCOUNT_REINSTATEMENT
  NOTE

  @@map("moderation_action_type")
}

enum SecurityEventSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@map("security_event_severity")
}

model User {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username              String                 @unique @db.Citext
  email                 String                 @unique @db.Citext
  passwordHash          String                 @map("password_hash") @db.VarChar(255)
  role                  UserRole               @default(USER)
  status                AccountStatus          @default(ACTIVE)
  emailVerified         Boolean                @default(false) @map("email_verified")
  emailVerifiedAt       DateTime?              @map("email_verified_at") @db.Timestamptz(6)
  lastLoginAt           DateTime?              @map("last_login_at") @db.Timestamptz(6)
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt             DateTime?              @map("deleted_at") @db.Timestamptz(6)
  profile               UserProfile?
  passwordResetTokens   PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  sessions              Session[]
  refreshTokens         RefreshToken[]
  loginHistory          LoginHistory[]
  securityEvents        SecurityEvent[]
  rateLimitBuckets      RateLimitBucket[]
  matchParticipants     MatchParticipant[]
  matchEvents           MatchEvent[]
  matchStats            UserMatchStat?
  reportsSubmitted      UserReport[]           @relation("ReportsSubmitted")
  reportsTargeting      UserReport[]           @relation("ReportsTargeting")
  moderationActionsAsActor ModerationAction[]   @relation("ModerationActor")
  moderationActionsAsTarget ModerationAction[]  @relation("ModerationTarget")
  auditLogsAsActor      AuditLog[]             @relation("AuditActor")
  adminNotesAuthored    AdminNote[]            @relation("AdminNoteAuthor")
  adminNotesReceived    AdminNote[]            @relation("AdminNoteTarget")
  bans                  BanHistory[]           @relation("BannedUser")
  bansIssued            BanHistory[]           @relation("BanIssuer")

  @@index([role, status], map: "idx_users_role_status")
  @@index([createdAt], map: "idx_users_created_at")
  @@index([lastLoginAt], map: "idx_users_last_login_at")
  @@map("users")
}

model UserProfile {
  userId                  String   @id @map("user_id") @db.Uuid
  profilePictureUrl       String?  @map("profile_picture_url") @db.VarChar(2048)
  displayName             String?  @map("display_name") @db.VarChar(120)
  biography               String?  @db.Text
  location                String?  @db.VarChar(160)
  birthDate               DateTime? @map("birth_date") @db.Date
  socialLinks             Json     @default("{}") @map("social_links") @db.JsonB
  preferences             Json     @default("{}") @db.JsonB
  matchmakingPreferences  Json     @default("{}") @map("matchmaking_preferences") @db.JsonB
  privacySettings         Json     @default("{}") @map("privacy_settings") @db.JsonB
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([displayName], map: "idx_user_profiles_display_name")
  @@index([location], map: "idx_user_profiles_location")
  @@map("user_profiles")
}

model PasswordResetToken {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String      @map("user_id") @db.Uuid
  tokenHash  String      @unique @map("token_hash") @db.VarChar(255)
  status     TokenStatus @default(ACTIVE)
  expiresAt  DateTime    @map("expires_at") @db.Timestamptz(6)
  usedAt     DateTime?   @map("used_at") @db.Timestamptz(6)
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  requestIp  String?     @map("request_ip") @db.Inet
  userAgent  String?     @map("user_agent") @db.Text
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, expiresAt], map: "idx_password_reset_tokens_user_status_expires")
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String      @map("user_id") @db.Uuid
  tokenHash  String      @unique @map("token_hash") @db.VarChar(255)
  status     TokenStatus @default(ACTIVE)
  expiresAt  DateTime    @map("expires_at") @db.Timestamptz(6)
  usedAt     DateTime?   @map("used_at") @db.Timestamptz(6)
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, expiresAt], map: "idx_email_verification_tokens_user_status_expires")
  @@map("email_verification_tokens")
}

model Session {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String        @map("user_id") @db.Uuid
  sessionTokenHash String    @unique @map("session_token_hash") @db.VarChar(255)
  status       SessionStatus @default(ACTIVE)
  ipAddress    String?       @map("ip_address") @db.Inet
  userAgent    String?       @map("user_agent") @db.Text
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  lastSeenAt   DateTime?     @map("last_seen_at") @db.Timestamptz(6)
  expiresAt    DateTime      @map("expires_at") @db.Timestamptz(6)
  revokedAt    DateTime?     @map("revoked_at") @db.Timestamptz(6)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([userId, status, expiresAt], map: "idx_sessions_user_status_expires")
  @@index([expiresAt], map: "idx_sessions_expires_at")
  @@map("sessions")
}

model RefreshToken {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  sessionId   String?       @map("session_id") @db.Uuid
  tokenHash   String        @unique @map("token_hash") @db.VarChar(255)
  status      TokenStatus   @default(ACTIVE)
  issuedAt    DateTime      @default(now()) @map("issued_at") @db.Timestamptz(6)
  expiresAt   DateTime      @map("expires_at") @db.Timestamptz(6)
  revokedAt   DateTime?     @map("revoked_at") @db.Timestamptz(6)
  replacedByTokenId String? @map("replaced_by_token_id") @db.Uuid
  ipAddress   String?       @map("ip_address") @db.Inet
  userAgent   String?       @map("user_agent") @db.Text
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  session     Session?      @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  replacedBy  RefreshToken? @relation("RefreshTokenRotation", fields: [replacedByTokenId], references: [id], onDelete: SetNull)
  replaces    RefreshToken[] @relation("RefreshTokenRotation")

  @@index([userId, status, expiresAt], map: "idx_refresh_tokens_user_status_expires")
  @@index([sessionId], map: "idx_refresh_tokens_session_id")
  @@map("refresh_tokens")
}

model LoginHistory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  emailAttempted String? @map("email_attempted") @db.Citext
  success     Boolean
  failureReason String? @map("failure_reason") @db.VarChar(120)
  ipAddress   String?  @map("ip_address") @db.Inet
  userAgent   String?  @map("user_agent") @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt], map: "idx_login_history_user_created")
  @@index([emailAttempted, createdAt], map: "idx_login_history_email_created")
  @@index([ipAddress, createdAt], map: "idx_login_history_ip_created")
  @@map("login_history")
}

model SecurityEvent {
  id          String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String?               @map("user_id") @db.Uuid
  eventType   String                @map("event_type") @db.VarChar(100)
  severity    SecurityEventSeverity @default(INFO)
  ipAddress   String?               @map("ip_address") @db.Inet
  userAgent   String?               @map("user_agent") @db.Text
  metadata    Json                  @default("{}") @db.JsonB
  createdAt   DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  user        User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt], map: "idx_security_events_user_created")
  @@index([eventType, createdAt], map: "idx_security_events_type_created")
  @@index([severity, createdAt], map: "idx_security_events_severity_created")
  @@map("security_events")
}

model RateLimitBucket {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  key         String   @db.VarChar(255)
  route       String   @db.VarChar(255)
  windowStart DateTime @map("window_start") @db.Timestamptz(6)
  windowSeconds Int    @map("window_seconds")
  requestCount Int     @default(0) @map("request_count")
  blockedUntil DateTime? @map("blocked_until") @db.Timestamptz(6)
  metadata    Json     @default("{}") @db.JsonB
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([key, route, windowStart], map: "uq_rate_limit_buckets_key_route_window")
  @@index([userId, route, windowStart], map: "idx_rate_limit_buckets_user_route_window")
  @@index([blockedUntil], map: "idx_rate_limit_buckets_blocked_until")
  @@map("rate_limit_buckets")
}

model Match {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  status      MatchStatus        @default(PENDING)
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  startedAt   DateTime?          @map("started_at") @db.Timestamptz(6)
  completedAt DateTime?          @map("completed_at") @db.Timestamptz(6)
  score       Json               @default("{}") @db.JsonB
  result      Json               @default("{}") @db.JsonB
  metadata    Json               @default("{}") @db.JsonB
  participants MatchParticipant[]
  events      MatchEvent[]
  analytics   MatchAnalytic[]

  @@index([status, createdAt], map: "idx_matches_status_created")
  @@index([completedAt], map: "idx_matches_completed_at")
  @@map("matches")
}

model MatchParticipant {
  id          String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  matchId     String                  @map("match_id") @db.Uuid
  userId      String                  @map("user_id") @db.Uuid
  joinedAt    DateTime                @default(now()) @map("joined_at") @db.Timestamptz(6)
  leftAt      DateTime?               @map("left_at") @db.Timestamptz(6)
  outcome     MatchParticipantOutcome @default(PENDING)
  score       Decimal?                @db.Decimal(12, 4)
  rank        Int?
  performance Json                    @default("{}") @db.JsonB
  metadata    Json                    @default("{}") @db.JsonB
  match       Match                   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId], map: "uq_match_participants_match_user")
  @@index([userId, joinedAt], map: "idx_match_participants_user_joined")
  @@index([matchId, outcome], map: "idx_match_participants_match_outcome")
  @@map("match_participants")
}

model UserMatchStat {
  userId          String   @id @map("user_id") @db.Uuid
  matchesPlayed   Int      @default(0) @map("matches_played")
  matchesWon      Int      @default(0) @map("matches_won")
  matchesLost     Int      @default(0) @map("matches_lost")
  matchesDrawn    Int      @default(0) @map("matches_drawn")
  averageScore    Decimal? @map("average_score") @db.Decimal(12, 4)
  highestScore    Decimal? @map("highest_score") @db.Decimal(12, 4)
  currentStreak   Int      @default(0) @map("current_streak")
  metadata        Json     @default("{}") @db.JsonB
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([matchesPlayed], map: "idx_user_match_stats_matches_played")
  @@index([averageScore], map: "idx_user_match_stats_average_score")
  @@map("user_match_stats")
}

model MatchEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  matchId   String   @map("match_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  eventType String   @map("event_type") @db.VarChar(100)
  payload   Json     @default("{}") @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([matchId, createdAt], map: "idx_match_events_match_created")
  @@index([eventType, createdAt], map: "idx_match_events_type_created")
  @@map("match_events")
}

model MatchAnalytic {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  matchId     String?  @map("match_id") @db.Uuid
  metricName  String   @map("metric_name") @db.VarChar(120)
  metricValue Decimal? @map("metric_value") @db.Decimal(18, 6)
  dimensions  Json     @default("{}") @db.JsonB
  recordedAt  DateTime @default(now()) @map("recorded_at") @db.Timestamptz(6)
  match       Match?   @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId, metricName, recordedAt], map: "idx_match_analytics_match_metric_recorded")
  @@index([metricName, recordedAt], map: "idx_match_analytics_metric_recorded")
  @@map("match_analytics")
}

model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String   @db.VarChar(120)
  entityType  String   @map("entity_type") @db.VarChar(120)
  entityId    String?  @map("entity_id") @db.Uuid
  before      Json?    @db.JsonB
  after       Json?    @db.JsonB
  metadata    Json     @default("{}") @db.JsonB
  ipAddress   String?  @map("ip_address") @db.Inet
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt], map: "idx_audit_logs_actor_created")
  @@index([entityType, entityId, createdAt], map: "idx_audit_logs_entity_created")
  @@index([action, createdAt], map: "idx_audit_logs_action_created")
  @@map("audit_logs")
}

model UserReport {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reporterUserId String?      @map("reporter_user_id") @db.Uuid
  targetUserId   String?      @map("target_user_id") @db.Uuid
  reportType     String       @map("report_type") @db.VarChar(100)
  subject        String?      @db.VarChar(255)
  description    String       @db.Text
  status         ReportStatus @default(OPEN)
  metadata       Json         @default("{}") @db.JsonB
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  resolvedAt     DateTime?    @map("resolved_at") @db.Timestamptz(6)
  reporter       User?        @relation("ReportsSubmitted", fields: [reporterUserId], references: [id], onDelete: SetNull)
  target         User?        @relation("ReportsTargeting", fields: [targetUserId], references: [id], onDelete: SetNull)
  actions        ModerationAction[]

  @@index([status, createdAt], map: "idx_user_reports_status_created")
  @@index([targetUserId, createdAt], map: "idx_user_reports_target_created")
  @@index([reporterUserId, createdAt], map: "idx_user_reports_reporter_created")
  @@map("user_reports")
}

model ModerationAction {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorUserId    String?              @map("actor_user_id") @db.Uuid
  targetUserId   String?              @map("target_user_id") @db.Uuid
  reportId       String?              @map("report_id") @db.Uuid
  actionType     ModerationActionType @map("action_type")
  reason         String?              @db.Text
  metadata       Json                 @default("{}") @db.JsonB
  startsAt       DateTime?            @map("starts_at") @db.Timestamptz(6)
  endsAt         DateTime?            @map("ends_at") @db.Timestamptz(6)
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  actor          User?                @relation("ModerationActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  target         User?                @relation("ModerationTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  report         UserReport?          @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([targetUserId, createdAt], map: "idx_moderation_actions_target_created")
  @@index([actorUserId, createdAt], map: "idx_moderation_actions_actor_created")
  @@index([reportId], map: "idx_moderation_actions_report_id")
  @@map("moderation_actions")
}

model AdminNote {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  targetUserId String   @map("target_user_id") @db.Uuid
  authorUserId String?  @map("author_user_id") @db.Uuid
  note         String   @db.Text
  metadata     Json     @default("{}") @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  target       User     @relation("AdminNoteTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  author       User?    @relation("AdminNoteAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([targetUserId, createdAt], map: "idx_admin_notes_target_created")
  @@index([authorUserId, createdAt], map: "idx_admin_notes_author_created")
  @@map("admin_notes")
}

model BanHistory {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  bannedByUserId String? @map("banned_by_user_id") @db.Uuid
  reason       String?  @db.Text
  startsAt     DateTime @default(now()) @map("starts_at") @db.Timestamptz(6)
  endsAt       DateTime? @map("ends_at") @db.Timestamptz(6)
  liftedAt     DateTime? @map("lifted_at") @db.Timestamptz(6)
  metadata     Json     @default("{}") @db.JsonB
  user         User     @relation("BannedUser", fields: [userId], references: [id], onDelete: Cascade)
  bannedBy     User?    @relation("BanIssuer", fields: [bannedByUserId], references: [id], onDelete: SetNull)

  @@index([userId, startsAt], map: "idx_ban_history_user_starts")
  @@index([endsAt], map: "idx_ban_history_ends_at")
  @@map("ban_history")
}

model SystemEvent {
  id          String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventType   String                @map("event_type") @db.VarChar(120)
  severity    SecurityEventSeverity @default(INFO)
  payload     Json                  @default("{}") @db.JsonB
  createdAt   DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([eventType, createdAt], map: "idx_system_events_type_created")
  @@index([severity, createdAt], map: "idx_system_events_severity_created")
  @@map("system_events")
}
