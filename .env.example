# Server-side only — never prefix secrets with VITE_
# Copy this file to .env for local development.

# Local development option
AI_PROVIDER=ollama
OLLAMA_MODEL=gemma3
OLLAMA_BASE_URL=http://localhost:11434

# Production option (set AI_PROVIDER=openai and a valid OPENAI_API_KEY)
# AI_PROVIDER=openai
OPENAI_API_KEY=

# Optional override for the generated public SQLite database
# PRELUDE_DATA_DB_PATH=./prelude_dataset_kit/data/db/prelude_public_data.sqlite

# Standalone API server port (npm run server)
# PRELUDE_API_PORT=3001

# Legacy Prisma/JWT auth database (optional if using Supabase only)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/prelude_dev?schema=public"
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-for-local-testing

# Public site URL for auth email links (verification, password reset).
PUBLIC_APP_URL=http://localhost:5173

# Client-side public origin for Supabase auth redirects (Cloudflare Pages production).
VITE_PUBLIC_APP_URL=https://preludev1.pages.dev
NODE_ENV=development

# Development only — ignored when NODE_ENV=production
# Auto-verify new Prisma accounts (skip email step locally)
PRELUDE_DEV_AUTO_VERIFY_EMAILS=1
# Show a clickable verification link on the register page after sign-up
PRELUDE_DEV_RETURN_VERIFY_LINK=1
# Also print auth links in the server terminal
PRELUDE_LOG_AUTH_EMAILS=0

# Production email (legacy Prisma auth) — Resend
RESEND_API_KEY=
AUTH_EMAIL_FROM=Prelude <accounts@yourdomain.com>

# Stripe Checkout subscriptions.
BILLING_PROVIDER=disabled
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID_BASIC=
STRIPE_PRICE_ID_PLUS=
STRIPE_PRICE_ID_PRO=

# Supabase (recommended primary auth)
# Put real values in .env.local (git-ignored). See SUPABASE_AUTH_SETUP.md.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Optional; defaults to window.location.origin when omitted.
# VITE_PUBLIC_APP_URL=https://preludev1.pages.dev
