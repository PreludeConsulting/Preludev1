# Server-side only — never prefix secrets with VITE_
# Copy this file to .env for local development.

# Local development option
AI_PROVIDER=ollama
OLLAMA_MODEL=gemma3
OLLAMA_BASE_URL=http://localhost:11434

# Production option (set AI_PROVIDER=openai and a valid OPENAI_API_KEY)
# AI_PROVIDER=openai
OPENAI_API_KEY=

# Optional override for the generated public SQLite database
# PRELUDE_DATA_DB_PATH=./prelude_dataset_kit/data/db/prelude_public_data.sqlite

# Standalone API server port (npm run server)
# PRELUDE_API_PORT=3001

# Local Prisma/JWT auth database (default for local development).
# Start Postgres with: npm run db:setup
DATABASE_URL="postgresql://prelude:prelude_dev_password@localhost:5432/prelude_dev?schema=public"
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-for-local-testing

# Public site URL for auth email links (verification, password reset).
PUBLIC_APP_URL=http://localhost:5173

# Client-side public origin for auth redirects (defaults to window.location.origin when omitted).
# VITE_PUBLIC_APP_URL=http://localhost:5173
NODE_ENV=development

# Development only — auto-sign in as the demo student and skip /login (never set in production).
# VITE_DEV_BYPASS_AUTH=1

# Development only — print verification/reset links in the server terminal (local testing).
# When RESEND_API_KEY and AUTH_EMAIL_FROM are set, real emails are sent even in development.
PRELUDE_LOG_AUTH_EMAILS=1

# Legacy local/API email sender and Cloudflare Pages Function login-code sender.
# Built-in Supabase Auth emails should be configured in Supabase Auth SMTP using Resend SMTP,
# not with VITE_* variables and not by frontend code.
RESEND_API_KEY=
AUTH_EMAIL_FROM=Prelude <no-reply@preludeconsultingllc.com>

# Discovery call booking email notifications.
CONTACT_SUPPORT_EMAIL=preludesupport@preludeconsultingllc.com
# Optional bug-report recipient override (defaults to CONTACT_SUPPORT_EMAIL, then Prelude Support).
BUG_REPORT_EMAIL=preludesupport@preludeconsultingllc.com

# Stripe Checkout subscriptions.
BILLING_PROVIDER=disabled
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Optional setup-script-only keys let you keep test/live credentials separate.
# Prefer restricted keys with only Products and Prices read/write permissions.
# STRIPE_TEST_SECRET_KEY=
# STRIPE_LIVE_SECRET_KEY=
STRIPE_PRICE_ID_BASIC=
STRIPE_PRICE_ID_PLUS=
STRIPE_PRICE_ID_PRO=
# Optional: pre-created Stripe coupon (20% off, duration once). Auto-created as prelude_referral_20_once if omitted.
# STRIPE_REFERRAL_COUPON_ID=prelude_referral_20_once
# One-time Essay Support package Prices.
STRIPE_PRICE_ID_ESSAY_SUPPORT_3=
STRIPE_PRICE_ID_ESSAY_SUPPORT_4=
STRIPE_PRICE_ID_ESSAY_SUPPORT_5=
STRIPE_PRICE_ID_ESSAY_SUPPORT_6=
STRIPE_PRICE_ID_ESSAY_SUPPORT_7=
STRIPE_PRICE_ID_ESSAY_SUPPORT_8=
STRIPE_PRICE_ID_ESSAY_SUPPORT_10=
# One-time Flexible Sessions package Prices.
STRIPE_PRICE_ID_FLEXIBLE_SESSIONS_3=
STRIPE_PRICE_ID_FLEXIBLE_SESSIONS_4=
STRIPE_PRICE_ID_FLEXIBLE_SESSIONS_5=
STRIPE_PRICE_ID_FLEXIBLE_SESSIONS_6=
STRIPE_PRICE_ID_FLEXIBLE_SESSIONS_7=
STRIPE_PRICE_ID_FLEXIBLE_SESSIONS_8=
STRIPE_PRICE_ID_FLEXIBLE_SESSIONS_10=
# Create or reuse the catalog safely (defaults to test mode):
# npm run stripe:catalog -- --write-env
# Live mode requires a live-mode STRIPE_SECRET_KEY and an explicit command:
# node scripts/setup-stripe-catalog.mjs --live
# Deprecated: SAT/ACT and Academic Tutoring are included as flexible session credits in Plus/Pro.
# STRIPE_PRICE_ID_SAT_ACT_PREP=
# STRIPE_PRICE_ID_ACADEMIC_TUTORING=

# Local Stripe webhook testing:
# 1. Run the app with `npm run dev`.
# 2. In another terminal run `npm run stripe:webhook`.
# 3. Copy the printed whsec_... value into STRIPE_WEBHOOK_SECRET above.

# Supabase (optional — leave empty for fully local Prisma/JWT auth).
# If set, the app uses Supabase instead of the local database for sign-up/login.
# See SUPABASE_AUTH_SETUP.md for cloud project setup.
VITE_PUBLIC_APP_URL=https://preludeconsultingllc.com
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
MENTOR_ACTIVITY_STORAGE_BUCKET=mentor-activity-submissions
MENTOR_ACTIVITY_MAX_FILE_BYTES=10485760
SUPABASE_URL=
# Server-side only. Required by Cloudflare Pages Functions for six-digit login verification.
SUPABASE_SERVICE_ROLE_KEY=
# Server-side only. Used to hash login codes, trusted-device tokens, and login assurances.
LOGIN_CODE_SECRET=

# Cron / admin secret for monthly referral-code rotation (min 16 chars).
# Used by POST /api/cron/rotate-referral-codes and npm run referral:rotate (CLI uses service role).
# Vercel Cron sends Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=

# Zoom API credentials (optional — not used for automatic meeting creation).
# Mentors paste Zoom join links manually when scheduling events or accepting requests.
# Leave blank unless you re-enable server-side Zoom API integration later.
# ZOOM_ACCOUNT_ID=
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=

# Public Cloudflare Turnstile site key for Supabase email auth CAPTCHA.
# Also enable CAPTCHA in Supabase Auth and configure the matching Turnstile secret there.
VITE_TURNSTILE_SITE_KEY=
