# Server-side only — never prefix secrets with VITE_
# Copy this file to .env for local development.

# Optional AI chat configuration
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Required for authentication/account APIs
DATABASE_URL=postgresql://prelude:prelude@localhost:5432/prelude?schema=public
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-for-local-testing

# Optional. If omitted, dev auth emails use the current Vite host/port + /Preludev1.
# Include /Preludev1 when using this repo's configured base path.
PUBLIC_APP_URL=http://localhost:5173/Preludev1
NODE_ENV=development
