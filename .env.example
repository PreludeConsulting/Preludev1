# Server-side only — never prefix secrets with VITE_
# Copy this file to .env for local development.

# Local development option
AI_PROVIDER=ollama
OLLAMA_MODEL=gemma3
OLLAMA_BASE_URL=http://localhost:11434

# Production option (set AI_PROVIDER=openai and a valid OPENAI_API_KEY)
# AI_PROVIDER=openai
OPENAI_API_KEY=

# Optional override for the generated public SQLite database
# PRELUDE_DATA_DB_PATH=./prelude_dataset_kit/data/db/prelude_public_data.sqlite

# Standalone API server port (npm run server)
# PRELUDE_API_PORT=3001

# Required for authentication/account APIs (matches compose.yml — copy to .env)
DATABASE_URL="postgresql://prelude:prelude_dev_password@localhost:5432/prelude_dev?schema=public"
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-for-local-testing

# Optional billing scaffold. Leave disabled until Stripe is ready.
BILLING_PROVIDER=disabled
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_PLUS_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=

# Optional. If omitted, dev auth emails use the current Vite host/port + /Preludev1.
PUBLIC_APP_URL=http://localhost:5173/Preludev1
NODE_ENV=development

# -----------------------------------------------------------------------------
# Supabase (OPTIONAL parallel auth stack under /auth/*)
# These are PUBLIC client values and are safe to expose with the VITE_ prefix.
# Put real values in .env.local (git-ignored), NOT here. See SUPABASE_AUTH_SETUP.md.
# Never put a service_role key, secret key, or SMTP password in frontend env.
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
