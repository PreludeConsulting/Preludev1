{
  "name": "prelude-landing-page",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server/standalone.js",
    "dev:all": "node scripts/dev-all.mjs",
    "db:start": "node scripts/db-start.mjs",
    "db:setup": "node scripts/db-setup.mjs",
    "db:reset": "node scripts/db-reset.mjs",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "seed:demo": "node scripts/seed-demo.mjs",
