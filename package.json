{
  "name": "prelude-landing-page",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server/standalone.js",
    "dev:all": "node scripts/dev-all.mjs",
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "db:setup": "node scripts/db-setup.mjs",
    "db:reset": "docker compose down -v && npm run db:setup",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "seed:demo": "prisma db seed",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run && node --test tests/server/*.node.test.js && node scripts/test-api-routes.mjs",
    "test:api:live": "node scripts/test-api-live.mjs",
    "test:watch": "vitest",
    "train:agent": "node scripts/train-agent.mjs"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/list": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@prisma/client": "^5.22.0",
    "argon2": "^0.44.0",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "dotenv": "^16.6.1",
    "hls.js": "^1.6.15",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.462.0",
    "motion": "^12.35.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "tailwind-merge": "^2.5.5",
    "zod": "^4.4.3"
  },
  "prisma": {
    "seed": "node scripts/seed-demo-accounts.mjs"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "allowScripts": {
    "@prisma/client@5.22.0": true,
    "@prisma/engines@5.22.0": true,
    "argon2@0.44.0": true,
    "esbuild@0.21.5": true,
    "prisma@5.22.0": true
  }
}
