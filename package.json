    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.108.1",
    "animejs": "^4.5.0",
    "argon2": "^0.44.0",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "d3-geo": "^3.1.1",
    "dotenv": "^16.6.1",
    "hls.js": "^1.6.15",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.462.0",
    "motion": "^12.35.0",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "stripe": "^22.2.0",
