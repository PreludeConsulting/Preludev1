    "sync:main": "node scripts/sync-main.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run && node --test tests/server/*.node.test.js && node scripts/test-api-routes.mjs",
    "test:api:live": "node scripts/test-api-live.mjs",
    "test:watch": "vitest",
    "train:agent": "node scripts/train-agent.mjs",
