{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "node"]
  },
  "include": [
    "src/lib/planBadges.js",
    "src/lib/motion/motionPolicy.js",
    "src/lib/landingNavigation.js",
    "server/chatRequest.js",
    "server/lib/loginAssurance.js",
    "server/lib/durableStorePolicy.js",
    "server/rag/guaranteeIntent.js"
  ],
  "exclude": ["node_modules", "dist", "server/data", "prelude_dataset_kit"]
}
